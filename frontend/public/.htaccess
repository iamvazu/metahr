<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Capture Shared Results for Bots/Crawlers (SEO Gateway)
  RewriteCond %{REQUEST_URI} ^/ee-in/results/([a-zA-Z0-9_-]+)$
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|LinkedInBot|WhatsApp|Twitterbot|Slackbot|Discordbot|TelegramBot|Googlebot|Bingbot) [NC]
  RewriteRule ^ee-in/results/([a-zA-Z0-9_-]+)$ results-meta.php?sessionId=$1 [L,QSA]

  # 2. If the file exists on the server, serve it directly
  # This covers all JS, CSS, and Image files
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. SPA Fallback (React Router)
  # EXCLUDE actual files, PHP, and WordPress core paths
  RewriteCond %{REQUEST_URI} !^/wp-(admin|content|includes|json|login|signup) [NC]
  RewriteCond %{REQUEST_URI} !^.*\.(js|css|png|jpg|jpeg|gif|svg|ico|json|txt|xml|php)$ [NC]
  RewriteRule ^(.*)$ /index.html [L]
</IfModule>
